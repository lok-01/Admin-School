@model Course
@{ ViewData["Title"] = "Add Course"; }
<div class="row justify-content-center"><div class="col-lg-6">
<div class="card shadow-sm"><div class="card-header bg-success text-white py-3"><h5 class="mb-0"><i class="bi bi-book me-2"></i>Add New Course</h5></div>
<div class="card-body p-4">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
        <div class="mb-3"><label asp-for="CourseName" class="form-label fw-semibold"></label><input asp-for="CourseName" class="form-control" placeholder="Course name" /><span asp-validation-for="CourseName" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="Duration" class="form-label fw-semibold"></label><input asp-for="Duration" class="form-control" placeholder="e.g. 3 Years" /><span asp-validation-for="Duration" class="text-danger small"></span></div>
        <div class="mb-4"><label asp-for="Fees" class="form-label fw-semibold"></label><div class="input-group"><span class="input-group-text">&#8377;</span><input asp-for="Fees" class="form-control" type="number" step="0.01" min="0" /></div><span asp-validation-for="Fees" class="text-danger small"></span></div>
        <div class="d-flex gap-2"><button type="submit" class="btn btn-success px-4"><i class="bi bi-check-lg me-1"></i>Save Course</button><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></div>
    </form>
</div></div></div></div>
