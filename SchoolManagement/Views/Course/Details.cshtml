@model Course
@{ ViewData["Title"] = "Course Details"; }
<div class="row justify-content-center"><div class="col-md-6">
<div class="card shadow-sm"><div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center"><h5 class="mb-0"><i class="bi bi-book me-2"></i>Course Details</h5><span class="badge bg-white text-info">ID: #@Model.CourseId</span></div>
<div class="card-body p-4"><dl class="row mb-0">
    <dt class="col-sm-4 text-muted">Course Name</dt><dd class="col-sm-8 fw-semibold">@Model.CourseName</dd>
    <dt class="col-sm-4 text-muted">Duration</dt><dd class="col-sm-8">@Model.Duration</dd>
    <dt class="col-sm-4 text-muted">Fees</dt><dd class="col-sm-8 text-success fw-bold fs-5">&#8377;@Model.Fees.ToString("N2")</dd>
</dl></div>
<div class="card-footer bg-white d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.CourseId" class="btn btn-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.CourseId" class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</a>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-auto"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div></div></div></div>
