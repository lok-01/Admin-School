<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - School Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="d-flex" style="min-height:100vh;">
        <!-- SIDEBAR -->
        <nav id="sidebar" class="sidebar bg-dark text-white d-flex flex-column" style="width:250px;min-height:100vh;position:fixed;top:0;left:0;z-index:100;">
            <div class="sidebar-brand d-flex align-items-center px-3 py-4 border-bottom border-secondary">
                <div class="brand-icon me-2"><i class="bi bi-mortarboard-fill text-warning fs-4"></i></div>
                <div>
                    <div class="fw-bold fs-6">SchoolMS</div>
                    <div class="text-secondary" style="font-size:11px;">Management System</div>
                </div>
            </div>
            <div class="px-2 py-3 flex-grow-1 overflow-auto">
                <div class="nav-section-label">MAIN</div>
                <a href="/Dashboard/Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Dashboard"?"active":"")">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
                <div class="nav-section-label mt-3">MASTER SETUP</div>
                <a href="/Student/Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Student"?"active":"")">
                    <i class="bi bi-people"></i> Students
                </a>
                <a href="/Course/Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Course"?"active":"")">
                    <i class="bi bi-book"></i> Courses
                </a>
                <a href="/Class/Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Class"?"active":"")">
                    <i class="bi bi-building"></i> Classes
                </a>
                <a href="/Subject/Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Subject"?"active":"")">
                    <i class="bi bi-journal-text"></i> Subjects
                </a>
                <a href="/Teacher/Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Teacher"?"active":"")">
                    <i class="bi bi-person-badge"></i> Teachers
                </a>
                <div class="nav-section-label mt-3">ACCOUNT</div>
                <a href="/Account/ChangePassword" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString()=="ChangePassword"?"active":"")">
                    <i class="bi bi-key"></i> Change Password
                </a>
                <a href="/Account/Logout" class="sidebar-link text-danger-emphasis">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
            <div class="px-3 py-3 border-top border-secondary">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center" style="width:34px;height:34px;">
                        <i class="bi bi-person-fill text-dark"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" style="font-size:13px;">@User.Identity.Name</div>
                        <div class="text-secondary" style="font-size:11px;">Administrator</div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <div style="margin-left:250px;width:calc(100% - 250px);">
            <!-- TOP NAV -->
            <div class="topbar bg-white border-bottom px-4 d-flex align-items-center justify-content-between" style="height:60px;position:sticky;top:0;z-index:99;">
                <h6 class="mb-0 fw-bold text-dark">@ViewData["Title"]</h6>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("ddd, dd MMM yyyy")</span>
                    <a href="/Account/Logout" class="btn btn-outline-danger btn-sm"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
                </div>
            </div>

            <!-- PAGE CONTENT -->
            <div class="p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Auto-dismiss alerts
    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(el => {
            try { bootstrap.Alert.getOrCreateInstance(el).close(); } catch(e){}
        });
    }, 4000);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
