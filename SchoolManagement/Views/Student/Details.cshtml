@model Student
@{ ViewData["Title"] = "Student Details"; }

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-person me-2"></i>Student Details</h5>
                <span class="badge bg-white text-info">ID: #@Model.StudentId</span>
            </div>
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Full Name</dt>
                    <dd class="col-sm-8 fw-semibold fs-6">@Model.Name</dd>
                    <dt class="col-sm-4 text-muted">Date of Birth</dt>
                    <dd class="col-sm-8">@Model.DOB.ToString("dd MMMM yyyy")</dd>
                    <dt class="col-sm-4 text-muted">Gender</dt>
                    <dd class="col-sm-8"><span class="badge @(Model.Gender=="Male"?"bg-primary":"bg-danger")">@Model.Gender</span></dd>
                    <dt class="col-sm-4 text-muted">Mobile</dt>
                    <dd class="col-sm-8">@Model.Mobile</dd>
                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4 text-muted">Address</dt>
                    <dd class="col-sm-8">@Model.Address</dd>
                </dl>
            </div>
            <div class="card-footer bg-white d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn btn-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.StudentId" class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-auto"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
            </div>
        </div>
    </div>
</div>
