@model IEnumerable<Subject>
@{ ViewData["Title"] = "Subjects"; }
<div class="card shadow-sm">
    <div class="card-header bg-white py-3 d-flex flex-wrap gap-2 align-items-center justify-content-between">
        <h6 class="mb-0 fw-bold"><i class="bi bi-journal-text me-2" style="color:#6f42c1"></i>All Subjects <span class="badge ms-1" style="background:#6f42c1">@Model.Count()</span></h6>
        <a asp-action="Create" class="btn btn-sm text-white" style="background:#6f42c1"><i class="bi bi-plus-lg me-1"></i>Add Subject</a>
    </div>
    <div class="card-body border-bottom pb-3">
        <form method="get" class="d-flex gap-2">
            <div class="input-group" style="max-width:380px;"><span class="input-group-text"><i class="bi bi-search text-muted"></i></span><input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search subjects or courses..." /><button class="btn btn-outline-secondary" type="submit">Search</button></div>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string)) { <a asp-action="Index" class="btn btn-outline-danger"><i class="bi bi-x"></i> Clear</a> }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light"><tr><th>#</th><th>Subject Name</th><th>Linked Course</th><th>Actions</th></tr></thead>
                <tbody>
                    @if (!Model.Any()) { <tr><td colspan="4" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No subjects found.</td></tr> }
                    @{ int i=1; }
                    @foreach (var s in Model) {
                    <tr>
                        <td class="text-muted">@(i++)</td><td class="fw-semibold">@s.SubjectName</td>
                        <td><span class="badge bg-primary bg-opacity-75">@s.Course?.CourseName</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@s.SubjectId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@s.SubjectId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@s.SubjectId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
