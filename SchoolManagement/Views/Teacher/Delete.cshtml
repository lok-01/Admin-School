@model Teacher
@{ ViewData["Title"] = "Delete Teacher"; }
<div class="row justify-content-center"><div class="col-md-5">
<div class="card shadow-sm border-danger"><div class="card-header bg-danger text-white py-3"><h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5></div>
<div class="card-body p-4 text-center">
    <i class="bi bi-person-x text-danger" style="font-size:4rem;"></i>
    <h5 class="mt-3">Delete this teacher?</h5>
    <div class="alert alert-light border text-start"><strong>Name:</strong> @Model.Name<br /><strong>Email:</strong> @Model.Email<br /><strong>Subject:</strong> @Model.Subject</div>
    <form asp-action="Delete" method="post" class="d-flex gap-2 justify-content-center">
        <input asp-for="TeacherId" type="hidden" />
        <button type="submit" class="btn btn-danger px-4"><i class="bi bi-trash me-1"></i>Yes, Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
    </form>
</div></div></div></div>
