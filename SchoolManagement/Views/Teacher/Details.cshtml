@model Teacher
@{ ViewData["Title"] = "Teacher Details"; }
<div class="row justify-content-center"><div class="col-md-6">
<div class="card shadow-sm"><div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center"><h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Teacher Details</h5><span class="badge bg-white text-info">ID: #@Model.TeacherId</span></div>
<div class="card-body p-4"><dl class="row mb-0">
    <dt class="col-sm-4 text-muted">Full Name</dt><dd class="col-sm-8 fw-semibold">@Model.Name</dd>
    <dt class="col-sm-4 text-muted">Mobile</dt><dd class="col-sm-8">@Model.Mobile</dd>
    <dt class="col-sm-4 text-muted">Email</dt><dd class="col-sm-8">@Model.Email</dd>
    <dt class="col-sm-4 text-muted">Subject</dt><dd class="col-sm-8"><span class="badge bg-danger">@Model.Subject</span></dd>
</dl></div>
<div class="card-footer bg-white d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.TeacherId" class="btn btn-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.TeacherId" class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</a>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-auto"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div></div></div></div>
