@model Teacher
@{ ViewData["Title"] = "Edit Teacher"; }
<div class="row justify-content-center"><div class="col-lg-7">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark py-3"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Teacher — @Model.Name</h5></div>
<div class="card-body p-4">
    <form asp-action="Edit" method="post">
        <input asp-for="TeacherId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Name" class="form-label fw-semibold"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger small"></span></div>
            <div class="col-md-6"><label asp-for="Mobile" class="form-label fw-semibold"></label><input asp-for="Mobile" class="form-control" /><span asp-validation-for="Mobile" class="text-danger small"></span></div>
            <div class="col-md-6"><label asp-for="Email" class="form-label fw-semibold"></label><input asp-for="Email" class="form-control" type="email" /><span asp-validation-for="Email" class="text-danger small"></span></div>
            <div class="col-md-6"><label asp-for="Subject" class="form-label fw-semibold"></label><input asp-for="Subject" class="form-control" /><span asp-validation-for="Subject" class="text-danger small"></span></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-warning px-4"><i class="bi bi-check-lg me-1"></i>Update Teacher</button><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></div>
    </form>
</div></div></div></div>
